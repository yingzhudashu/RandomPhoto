<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:padding="6dp"
    android:background="#3F51B5">

    <!-- 左侧：照片显示区域 -->
    <ImageView
        android:id="@+id/widget_photo"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:scaleType="fitCenter"
        android:adjustViewBounds="true"
        android:background="#33FFFFFF"
        android:contentDescription="随机照片"
        android:layout_marginEnd="6dp" />

    <!-- 右侧：按钮区域 -->
    <LinearLayout
        android:layout_width="88dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center">

        <!-- 照片信息 -->
        <TextView
            android:id="@+id/widget_photo_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="点击加载"
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginBottom="4dp" />

        <!-- 随机按钮 -->
        <Button
            android:id="@+id/widget_random_button"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="🎲 随机"
            android:textSize="12sp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:layout_marginBottom="3dp" />

        <!-- 删除按钮 -->
        <Button
            android:id="@+id/widget_delete_button"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="🗑️ 删除"
            android:textSize="12sp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:layout_marginBottom="3dp" />

        <!-- 隐藏按钮 -->
        <Button
            android:id="@+id/widget_hide_button"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="🔒 隐藏"
            android:textSize="12sp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:layout_marginBottom="3dp" />

        <!-- 回收站按钮 -->
        <Button
            android:id="@+id/widget_recycle_bin_button"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="♻️ 回收"
            android:textSize="12sp"
            android:minWidth="0dp"
            android:minHeight="0dp" />

    </LinearLayout>

</LinearLayout>
